# ─────────────────────────────────────────────────────────────────
# Oracle Cloud .env template — copy to project root as `.env` on the host.
#
# Required for production (validate_runtime_settings will refuse to
# start without these):
# ─────────────────────────────────────────────────────────────────
SERP_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
LLM_PROVIDER=openrouter

GOOGLE_SHEET_ID=
# Either point at the JSON file uploaded via scp ...
GOOGLE_CREDENTIALS_FILE=/home/ubuntu/hyperliquid-perps-analyzer/credentials.json
# ...or paste the entire JSON inline (escape newlines if you do):
# GOOGLE_CREDENTIALS_JSON=

HL_PERP_DEX=xyz
CRON_INTERVAL_SECONDS=60

# ─────────────────────────────────────────────────────────────────
# Telegram (added in feat/reliability-backlog)
# ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STRONG_ONLY=false
TELEGRAM_MIN_SCORE=0

# ─────────────────────────────────────────────────────────────────
# Events calendar (Finnhub free tier: https://finnhub.io)
# ─────────────────────────────────────────────────────────────────
FINNHUB_API_KEY=
EVENTS_CONTEXT_ENABLED=true
EVENTS_LOOKAHEAD_DAYS=14
EVENTS_PRE_EARNINGS_DAYS=5
EVENTS_MACRO_HORIZON_DAYS=3
EVENTS_EARNINGS_HORIZON_DAYS=90

# ─────────────────────────────────────────────────────────────────
# Live technicals on every alert
# ─────────────────────────────────────────────────────────────────
TECHNICALS_ENABLED=true

# ─────────────────────────────────────────────────────────────────
# Reliability backlog flags
# ─────────────────────────────────────────────────────────────────
ENABLE_CROSS_CHECK=false
CROSS_CHECK_MODEL=anthropic/claude-haiku-4.5

FRESHNESS_ENABLED=true
FRESHNESS_REPEAT_LIMIT=3

ALERTS_JSONL_PATH=/home/ubuntu/hyperliquid-perps-analyzer/eval/alerts.jsonl
